<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>FlowDesk</RootNamespace>
    <AssemblyName>FlowDesk</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>assets\app_icon.ico</ApplicationIcon>
    <AssemblyTitle>FlowDesk</AssemblyTitle>
    <Product>FlowDesk</Product>
    <Description>FlowDesk Remote Desktop - Server (Windows)</Description>
    <Version>1.0.0</Version>
    <Company>FlowDesk</Company>
    <Copyright>Copyright (c) 2026</Copyright>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="QRCoder" Version="1.6.0" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
    <PackageReference Include="System.Drawing.Common" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="assets\app_icon.ico" />
    <Resource Include="assets\app_icon.png" />
  </ItemGroup>

</Project>
