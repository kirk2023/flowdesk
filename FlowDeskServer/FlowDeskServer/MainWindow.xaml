<Window x:Class="FlowDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="FlowDesk" 
        Height="640" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Icon="assets/app_icon.ico"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" Padding="20,16">
            <StackPanel>
                <TextBlock Text="FlowDesk" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="远程桌面被控端" Foreground="#CCFFFFFF" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="20,20,20,0">

            <!-- Device ID -->
            <TextBlock Text="设备 ID" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="Medium"/>
            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="14,10" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DeviceIdText" Grid.Column="0"
                               Text="8K7M-3XQ2-NP5R"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20" FontFamily="Consolas, monospace"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="CopyIdButton" Content="复制"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4" FontSize="11" Click="CopyIdButton_Click"/>
                </Grid>
            </Border>

            <!-- PIN -->
            <TextBlock Text="动态 PIN" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="Medium" Margin="0,16,0,0"/>
            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="14,12" Margin="0,6,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="PinText" Grid.Column="0"
                               Text="0 0 0 0 0 0"
                               Foreground="{StaticResource PrimaryBrush}"
                               FontSize="32" FontFamily="Consolas, monospace"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="PinCountdownText" Text="30s"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   FontSize="12" HorizontalAlignment="Right"/>
                        <TextBlock Text="自动刷新" Foreground="{StaticResource TextTertiaryBrush}"
                                   FontSize="10" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Network info (prominent) -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="10,8" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock x:Name="NetworkInfoText" Text="本机 IP: 加载中..."
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" HorizontalAlignment="Center" FontWeight="Medium"/>
                    <TextBlock Text="请确保手机连接同一 WiFi 扫码"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- QR Code -->
            <Border Background="{StaticResource CardBrush}" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <StackPanel>
                    <Image x:Name="QrCodeImage" Height="150" Width="150" Stretch="Uniform" Margin="0,0,0,6"/>
                    <TextBlock Text="扫码配对（手机 FlowDesk → 添加 → 扫码）"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="10" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Connection status -->
            <Border x:Name="StatusBadge" Background="#E8F5E9" CornerRadius="6" Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock x:Name="StatusText" Text="已配对：等待连接..."
                           Foreground="#2E7D32" FontSize="12" HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" Padding="20,12">
            <StackPanel>
                <Button Content="打开日志文件夹" HorizontalAlignment="Center" Padding="12,4"
                        FontSize="11" Click="OpenLogButton_Click"
                        Style="{StaticResource SecondaryButton}"/>
                <TextBlock Text="FlowDesk v1.0.0 (MVP)" Foreground="{StaticResource TextTertiaryBrush}"
                           FontSize="10" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="纯局域网 P2P · 无服务器 · 端到端加密"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tray icon (set up in code) -->
        <tb:TaskbarIcon x:Name="Tray" Visibility="Collapsed" TrayMouseDoubleClick="Tray_DoubleClick"/>
    </Grid>
</Window>
